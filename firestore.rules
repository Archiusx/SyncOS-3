rules_version = '2';
// SYNC-OS SECURITY ARCHITECTURE: Hardened Firestore Security Rules.
// Implements Attribute-Based Access Control (ABAC) and ID Poisoning Guard.
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, displayName, email, grade, lastActive
    //
    // Collection: notes
    // Fields: uid, title, content, updatedAt
    //
    // Collection: modules
    // Fields: uid, topic, type, data, createdAt
    //
    // Collection: progress
    // Fields: uid, subject, progress, timestamp
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isValidString(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && request.resource.data.uid == uid;
    }

    match /notes/{noteId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /modules/{moduleId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /progress/{progressId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
